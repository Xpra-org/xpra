include COPYING README.md
include xpra/buffers/memalign.h
include xpra/buffers/memalign.c
include xpra/buffers/xxh3.h
include xpra/codecs/libva/va_common.h
include xpra/codecs/libva/va_decode.c
include xpra/codecs/libva/va_decode.h
include xpra/codecs/libva/va_encode.c
include xpra/codecs/libva/va_encode.h
include xpra/codecs/libva/va_vpx_tables.h
include xpra/codecs/mf/mf_decode.c
include xpra/codecs/mf/mf_decode.h
include xpra/codecs/vpl/vpl_decode.c
include xpra/codecs/vpl/vpl_decode.h
include xpra/codecs/vpl/vpl_encode.c
include xpra/codecs/vpl/vpl_encode.h
include xpra/codecs/vpl/vpl_log.h
include xpra/codecs/v4l2/video.h
include xpra/net/lz4/lz4_compat.h
include xpra/platform/darwin/nsevent_glue.h
include xpra/platform/darwin/transparency_glue.h
include xpra/platform/win32/setappid.cpp
include xpra/platform/win32/setappid.h
include xpra/x11/gtk/gdk_x11_macros.c
include xpra/x11/gtk/gdk_x11_macros.h
prune html5
recursive-include fs *
recursive-include docs *
recursive-include tests __init__.py perf scripts
recursive-include tests/unittests run unit
recursive-include packaging/debian *
recursive-include packaging/arch *
recursive-include packaging/MacOS *
recursive-include packaging/MSWindows *
recursive-include packaging/rpm *
global-include *.py *.txt *.pyx *.pxd
global-exclude *~ \#* *.orig *.bak *.rej *.pxi
prune venv
prune build
prune dist
prune cache
prune opt
