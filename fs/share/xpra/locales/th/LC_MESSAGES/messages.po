#: xpra/client/gtk3/tray_menu.py:188
msgid "Information"
msgstr "ข้อมูล"

#: xpra/client/gtk3/tray_menu.py:213 xpra/gtk/dialogs/session_info.py:732
msgid "Features"
msgstr "คุณสมบัติ"

#: xpra/client/gtk3/tray_menu.py:247
msgid "Allow other clients to connect to this session"
msgstr "อนุญาตให้ไคลเอนต์อื่นเชื่อมต่อกับเซสชันนี้"

#: xpra/client/gtk3/tray_menu.py:257
msgid "Sharing is disabled on the server"
